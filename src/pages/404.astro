---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — Tom Carpen">
  <main class="wrap lost">
    <p class="eyebrow">404</p>
    <h1>This page went off the grid.</h1>
    <p class="lost-sub">The page you're looking for doesn't exist or has moved.</p>
    <a class="lost-link mono" href="/">← Back to home</a>
  </main>
</Base>

<style>
  .lost {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
  }

  .lost h1 {
    font-size: var(--step-h2);
  }

  .lost-sub {
    color: var(--muted);
  }

  .lost-link {
    color: var(--turmeric);
  }
</style>
