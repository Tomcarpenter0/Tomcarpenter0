---
// Generated cover art — one abstract motif per case study era.
interface Props {
  variant: 'halftone' | 'stalls' | 'routes' | 'orbit';
  accent: string;
  transitionName?: string;
}

const { variant, accent, transitionName } = Astro.props;

// halftone: newsprint dot screen (Kompas era)
const dots: { cx: number; cy: number; r: number }[] = [];
if (variant === 'halftone') {
  for (let row = 0; row < 9; row++) {
    for (let col = 0; col < 14; col++) {
      dots.push({
        cx: 40 + col * 56,
        cy: 40 + row * 60,
        r: 2 + 11 * Math.abs(Math.sin(col * 0.55 + row * 0.85)),
      });
    }
  }
}

// stalls: marketplace card grid (Tokopedia era)
const stalls: { x: number; y: number; on: boolean }[] = [];
if (variant === 'stalls') {
  for (let row = 0; row < 3; row++) {
    for (let col = 0; col < 5; col++) {
      stalls.push({
        x: 40 + col * 148,
        y: 48 + row * 164,
        on: (row * 5 + col) % 4 === 1,
      });
    }
  }
}
---

<div class="cover" transition:name={transitionName}>
  <svg
    viewBox="0 0 800 560"
    role="img"
    aria-label="Abstract cover artwork"
    preserveAspectRatio="xMidYMid slice"
    data-parallax
  >
    <rect width="800" height="560" fill="var(--indigo-900)"></rect>

    {
      variant === 'halftone' &&
        dots.map((d) => <circle cx={d.cx} cy={d.cy} r={d.r} fill={accent} opacity="0.85" />)
    }

    {
      variant === 'stalls' &&
        stalls.map((s) => (
          <rect
            x={s.x}
            y={s.y}
            width="120"
            height="132"
            rx="14"
            fill={s.on ? accent : 'none'}
            stroke={accent}
            stroke-width="3"
            opacity={s.on ? '0.9' : '0.5'}
          />
        ))
    }

    {
      variant === 'routes' && (
        <g fill="none" stroke={accent} stroke-width="4">
          <path d="M60 470 C 220 420, 260 220, 420 200 S 700 120, 740 80" stroke-dasharray="2 14" stroke-linecap="round" />
          <path d="M80 120 C 200 180, 340 400, 560 420 S 700 460, 750 480" opacity="0.45" />
          <circle cx="60" cy="470" r="12" fill={accent} stroke="none" />
          <circle cx="740" cy="80" r="12" fill="var(--paper)" stroke="none" />
          <circle cx="420" cy="200" r="26" stroke-width="3" opacity="0.7" />
        </g>
      )
    }

    {
      variant === 'orbit' && (
        <g fill="none" stroke={accent}>
          <circle cx="400" cy="280" r="70" stroke-width="3" opacity="0.9" />
          <circle cx="400" cy="280" r="130" stroke-width="2" opacity="0.6" />
          <circle cx="400" cy="280" r="190" stroke-width="2" opacity="0.35" />
          <path d="M400 30 A 250 250 0 0 1 650 280" stroke-width="5" stroke-linecap="round" />
          <circle cx="650" cy="280" r="16" fill={accent} stroke="none" />
          <circle cx="400" cy="280" r="26" fill="var(--paper)" stroke="none" />
        </g>
      )
    }
  </svg>
</div>

<style>
  .cover {
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--line);
  }

  .cover svg {
    width: 100%;
    height: auto;
    /* headroom so the parallax shift never exposes edges */
    scale: 1.12;
  }
</style>
